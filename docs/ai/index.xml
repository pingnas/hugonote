<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Note</title><link>https://pingnas.github.io/hugonote/docs/ai/</link><description>Recent content on Note</description><generator>Hugo</generator><language>en-us</language><atom:link href="https://pingnas.github.io/hugonote/docs/ai/index.xml" rel="self" type="application/rss+xml"/><item><title/><link>https://pingnas.github.io/hugonote/docs/ai/skills/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://pingnas.github.io/hugonote/docs/ai/skills/</guid><description>&lt;h1 id="skills"&gt;Skills&lt;a class="anchor" href="#skills"&gt;#&lt;/a&gt;&lt;/h1&gt;
&lt;h2 id="参考"&gt;参考&lt;a class="anchor" href="#%e5%8f%82%e8%80%83"&gt;#&lt;/a&gt;&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href="https://github.com/vercel-labs/skills"&gt;skills&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href="https://skills.sh/"&gt;skills.sh&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="命令"&gt;命令&lt;a class="anchor" href="#%e5%91%bd%e4%bb%a4"&gt;#&lt;/a&gt;&lt;/h2&gt;
&lt;h3 id="添加skills"&gt;添加skills&lt;a class="anchor" href="#%e6%b7%bb%e5%8a%a0skills"&gt;#&lt;/a&gt;&lt;/h3&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#2f1e2e;background-color:#e7e9db;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-sh" data-lang="sh"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#8d8687"&gt;# GitHub 简写 (owner/repo)&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;npx skills add vercel-labs/agent-skills
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#8d8687"&gt;# 完整 GitHub URL&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;npx skills add https://github.com/vercel-labs/agent-skills
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#8d8687"&gt;# 仓库中某项技能的直接路径&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;npx skills add https://github.com/vercel-labs/agent-skills/tree/main/skills/web-design-guidelines
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#8d8687"&gt;# GitLab URL&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;npx skills add https://gitlab.com/org/repo
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#8d8687"&gt;# Any git URL&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;npx skills add git@github.com:vercel-labs/agent-skills.git
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#8d8687"&gt;# Local path&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;npx skills add ./my-local-skills&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;blockquote class='book-hint '&gt;
&lt;p&gt;&lt;code&gt;-g, --global&lt;/code&gt; 安装到用户目录而不是项目目录(默认是项目目录)&lt;/p&gt;
&lt;/blockquote&gt;&lt;blockquote class='book-hint '&gt;
&lt;p&gt;&lt;code&gt;-a, --agent &amp;lt;agents...&amp;gt;&lt;/code&gt; 指定目标Agents : &lt;a href="https://github.com/vercel-labs/skills?tab=readme-ov-file#supported-agents"&gt;https://github.com/vercel-labs/skills?tab=readme-ov-file#supported-agents&lt;/a&gt;&lt;/p&gt;
&lt;/blockquote&gt;&lt;blockquote class='book-hint '&gt;
&lt;p&gt;&lt;code&gt;-s, --skill &amp;lt;skills...&amp;gt;&lt;/code&gt; 按名称安装特定技能（使用“*”安装所有技能）&lt;/p&gt;</description></item></channel></rss>